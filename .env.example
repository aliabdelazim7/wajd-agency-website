# إعدادات قاعدة بيانات Supabase
# استبدل القيم أدناه ببيانات مشروعك الخاص في Supabase

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# مفتاح الوصول لخدمة Web3Forms لإرسال إشعارات البريد الإلكتروني (اختياري)
# إذا تركتها فارغة، فسيتم إرسال الإشعارات تلقائياً باستخدام FormSubmit.co
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here

